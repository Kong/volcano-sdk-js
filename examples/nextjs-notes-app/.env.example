# Volcano SDK Configuration
# Copy this file to .env.local and fill in your values

# Your Volcano API URL (optional - defaults to https://api.volcano.dev)
# Only set this for local development or self-hosted deployments
# NEXT_PUBLIC_VOLCANO_API_URL=http://localhost:8000

# Your project's anonymous key (public, safe for frontend)
# Find this in your Volcano dashboard under Project Settings > API Keys
NEXT_PUBLIC_VOLCANO_ANON_KEY=your-anon-key-here

# Your database name (e.g., "notes_db", "my_app_db")
# Lowercase letters, numbers, and underscores only
NEXT_PUBLIC_VOLCANO_DATABASE_NAME=your_database_name_here
